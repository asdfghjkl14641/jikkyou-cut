{
  "name": "jikkyou-cut",
  "productName": "jikkyou-cut",
  "version": "0.0.1",
  "description": "ゲーム実況・配信切り抜きに特化したテキストベース動画編集ツール",
  "license": "GPL-2.0-or-later",
  "main": "./out/main/index.js",
  "homepage": "./",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "build": {
    "extraResources": [
      {
        "from": "resources/yt-dlp",
        "to": "yt-dlp",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/tray-icon.png",
        "to": "tray-icon.png"
      },
      {
        "from": "resources/tray-icon-live.png",
        "to": "tray-icon-live.png"
      }
    ]
  },
  "scripts": {
    "dev": "electron-vite dev -w",
    "dev:fresh": "node -e \"require('fs').rmSync('out',{recursive:true,force:true})\" && electron-vite dev -w",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "tsc": "tsc --build"
  },
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.9.0",
    "execa": "^9.6.1",
    "lucide-react": "^1.11.0",
    "nanoid": "^5.1.9",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "~5.6.3",
    "vite": "^5.4.11"
  }
}
